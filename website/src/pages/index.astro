---
import BaseLayout from "../layouts/BaseLayout.astro";
import AgentCard from "../components/AgentCard.astro";
import { agents, githubUrl, workflowSteps } from "../data/site";
---

<BaseLayout
  title="The operating harness for community business"
  description="Kingdom of PAL is a pre-release organisational harness for coordinating community insight, content, security and system health under founder control."
>
  <section class="hero">
    <img
      class="hero-engraving"
      src="/kingdom-command-stage.png"
      alt=""
      width="1536"
      height="1024"
      aria-hidden="true"
    />
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">
          Community-business harness · Human governed · Pre-release
        </p>
        <h1>
          Your charter. Your final word. <em>Four specialists</em> at your command.
        </h1>
        <p class="lead">
          Kingdom of PAL turns your charter into coordinated community-business
          workflows. Orin understands the community. Scribe creates. Rick
          protects. Bastion diagnoses. You keep the final word.
        </p>
        <div class="button-row">
          <a class="button" href="/demo"
            >Watch the demo <span aria-hidden="true">&nbsp;→</span></a
          >
          <a class="button button-secondary" href="/early-access"
            >Join early access</a
          >
          <a class="text-link" href={githubUrl}
            >View on GitHub <span aria-hidden="true">↗</span></a
          >
        </div>
        <p class="pre-release-note">
          Pre-release website · Interactive demonstration · No runnable platform
          or installer yet
        </p>
      </div>
      <div
        class="workflow-console"
        aria-label="Preview of the governed community campaign workflow"
      >
        <div class="console-head">
          <span>community-campaign.yaml</span><span>Demo preview</span>
        </div>
        <ol class="console-list">
          <li>
            <div>
              <strong>Orin identifies a recurring need</strong><span
                >risk: low / routed</span
              >
            </div>
          </li>
          <li>
            <div>
              <strong>Scribe creates the campaign</strong><span
                >risk: low / draft only</span
              >
            </div>
          </li>
          <li>
            <div>
              <strong>Rick reviews privacy and policy</strong><span
                >risk: medium / security review</span
              >
            </div>
          </li>
          <li>
            <div>
              <strong>Founder approves publication</strong><span
                class="approval">approval: required</span
              >
            </div>
          </li>
          <li>
            <div>
              <strong>Outcome and decision are recorded</strong><span
                >audit: reviewable</span
              >
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <section class="section section-lined" aria-labelledby="bottleneck-heading">
    <div class="shell split">
      <div>
        <p class="eyebrow">The founder bottleneck</p>
        <h2 id="bottleneck-heading">
          Your tools can generate. You still have to operate.
        </h2>
        <p class="lead">
          The founder carries context between disconnected tools, checks every
          handoff, and becomes the operating system.
        </p>
      </div>
      <div
        class="comparison"
        aria-label="Disconnected tools compared with Kingdom of PAL"
      >
        <div class="comparison-row">
          <span>Repeated prompting</span><b aria-hidden="true">→</b><strong
            >Shared organisational context</strong
          >
        </div>
        <div class="comparison-row">
          <span>Manual handoffs</span><b aria-hidden="true">→</b><strong
            >Contract-based workflows</strong
          >
        </div>
        <div class="comparison-row">
          <span>Unclear permissions</span><b aria-hidden="true">→</b><strong
            >Bounded agent access</strong
          >
        </div>
        <div class="comparison-row">
          <span>Hidden failures</span><b aria-hidden="true">→</b><strong
            >Reviewable decisions</strong
          >
        </div>
        <div class="comparison-row">
          <span>Founder checks everything</span><b aria-hidden="true">→</b
          ><strong>Risk-based approval</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section harness-section" aria-labelledby="harness-heading">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="eyebrow">The organisational harness</p>
          <h2 id="harness-heading">
            Manage the community business as one system.
          </h2>
        </div>
        <p class="lead">
          This is not a collection of chatbots. The harness is designed to carry
          founder intent, permitted context and accountable work across business
          functions—without making the founder the integration layer.
        </p>
      </div>

      <div class="harness-map" data-motion-group>
        <article class="harness-column founder-inputs">
          <p class="harness-label">01 / You define the kingdom</p>
          <h3>Founder’s Charter</h3>
          <p>Your operating context becomes the common brief for every role.</p>
          <ul>
            <li>Mission, values and community promise</li>
            <li>Brand voice and current priorities</li>
            <li>Approval rules and prohibited actions</li>
            <li>Success measures and operating principles</li>
          </ul>
        </article>

        <div
          class="harness-core"
          aria-label="Kingdom of PAL organisational layers"
        >
          <p class="harness-label">02 / Kingdom of PAL coordinates</p>
          <ol>
            <li><span>Charter</span><strong>Shared direction</strong></li>
            <li><span>Registry</span><strong>Roles and permissions</strong></li>
            <li><span>Contracts</span><strong>Reliable handoffs</strong></li>
            <li>
              <span>Workflows</span><strong>Cross-agent execution</strong>
            </li>
            <li><span>Policies</span><strong>Risk and approvals</strong></li>
            <li>
              <span>Memory</span><strong>Intended reusable context</strong>
            </li>
          </ol>
        </div>

        <article class="harness-column business-outputs">
          <p class="harness-label">03 / The team operates</p>
          <h3>Community-business functions</h3>
          <p>
            Each function has a specialist owner, a declared boundary and an
            escalation path.
          </p>
          <ul>
            <li><b>Community</b> recurring needs and routed work</li>
            <li><b>Content</b> articles, education and channel versions</li>
            <li><b>Governance</b> privacy, permissions and policy review</li>
            <li><b>Operations</b> agent, integration and memory diagnosis</li>
          </ul>
        </article>
      </div>

      <div class="harness-status" role="note">
        <strong>Pre-release boundary</strong>
        <span>
          The repository currently defines the charter, registry, contracts,
          policies and workflows. Running agents, persistent memory,
          integrations and hosted execution remain future runtime functionality.
        </span>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="agents-heading">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="eyebrow">The essential kingdom</p><h2 id="agents-heading">
            Four specialist agents. One human authority.
          </h2>
        </div>
        <p class="lead">
          The founder’s technical retinue carries out bounded work. Each agent
          owns a clear job and a hard boundary; consequential decisions stay
          with the human in command.
        </p>
      </div>
      <div class="agent-grid" data-motion-group>
        {agents.map((agent) => <AgentCard agent={agent} />)}
      </div>
      <p style="margin-top: 28px">
        <a class="text-link" href="/agents"
          >Understand the agent lifecycle <span aria-hidden="true">→</span></a
        >
      </p>
    </div>
  </section>

  <section
    class="section section-dark central-demo"
    aria-labelledby="workflow-heading"
  >
    <div class="shell">
      <div class="demo-intro">
        <p class="eyebrow">
          Central demonstration · Governed community campaign
        </p>
        <h2 id="workflow-heading">
          One community question becomes a governed campaign.
        </h2>
        <p class="lead">
          The team can prepare work autonomously. Publication crosses a
          boundary, so Rick reviews and the founder decides.
        </p>
      </div>
      <ol class="workflow-track" data-motion-group>
        {
          workflowSteps.map((step, index) => (
            <li class="workflow-node" style={`--i: ${index}`}>
              <>
                <span class="number">
                  0{index + 1} / {step.actor}
                </span>
                <h3>{step.title}</h3>
                <p>{step.detail}</p>
                <span class="risk">{step.risk}</span>
              </>
            </li>
          ))
        }
      </ol>
      <div class="button-row demo-actions">
        <a class="button" href="/demo"
          >Watch the demo <span aria-hidden="true">&nbsp;→</span></a
        >
        <a class="button button-secondary" href="/docs#workflow-definition"
          >View the workflow definition</a
        >
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="risk-heading">
    <div class="shell">
      <p class="eyebrow">Risk-based governance</p>
      <h2 id="risk-heading">Autonomy increases only when risk is explicit.</h2>
      <p class="lead">
        Unknown actions default to high risk. Missing approvals are denied, and
        decisions are recorded.
      </p>
      <div class="risk-grid">
        <article class="risk-card">
          <span class="risk-index">01 / Low risk</span><h3>
            Automatic preparation
          </h3><p>
            Agents may draft, summarise, organise, plan and run read-only health
            checks.
          </p><ul>
            <li>No external publication</li><li>Reviewable outputs</li>
          </ul>
        </article>
        <article class="risk-card">
          <span class="risk-index">02 / Medium risk</span><h3>
            Founder approval
          </h3><p>
            Publishing, messaging, website changes and operational fixes require
            the founder.
          </p><ul>
            <li>Security review when needed</li><li>No silent execution</li>
          </ul>
        </article>
        <article class="risk-card">
          <span class="risk-index">03 / High risk</span><h3>
            Security + founder
          </h3><p>
            Production, money, credentials, permissions and private information
            require both controls.
          </p><ul>
            <li>Explicit approval</li><li>Security review required</li>
          </ul>
        </article>
      </div>
      <p style="margin-top: 32px">
        <a class="text-link" href="/security"
          >Read the security model <span aria-hidden="true">→</span></a
        >
      </p>
    </div>
  </section>

  <section class="section section-lined" aria-labelledby="lifecycle-heading">
    <div class="shell">
      <p class="eyebrow">Stable roles · Evolvable implementations</p>
      <h2 id="lifecycle-heading">A protected core. An extensible edge.</h2>
      <p class="lead">
        The first kingdom is being assembled. The current repository defines
        lifecycle rules; extension installation is future functionality.
      </p>
      <div class="lifecycle-grid">
        <article class="lifecycle-card core">
          <p class="label">Mandatory core roles</p><h3>
            Always represented in a healthy kingdom
          </h3><ul>
            <li>
              Orin, Scribe, Rick and Bastion are non-removable through the
              normal lifecycle.
            </li><li>
              An implementation may be replaced only when a contract-compatible
              replacement is ready.
            </li>
          </ul>
        </article>
        <article class="lifecycle-card extension">
          <p class="label">Future extension agents</p><h3>
            Capability without permanent lock-in
          </h3><ul>
            <li>
              Extensions may be installed, disabled, upgraded or removed.
            </li><li>
              Removal preserves audit history and archives memory provenance.
            </li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="trust-heading">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="eyebrow">Verifiable architecture</p><h2 id="trust-heading">
            Trust the contracts, not the theatre.
          </h2>
        </div><p class="lead">
          The repository provides evidence for the organisational model. Runtime
          capabilities remain pre-release.
        </p>
      </div>
      <div class="trust-row">
        <article class="trust-item">
          <code>agent-registry.yaml</code><h3>Declared roles</h3><p>
            Capabilities, permissions, boundaries and lifecycle rules for all
            four agents.
          </p>
        </article>
        <article class="trust-item">
          <code>shared-contracts/*</code><h3>Versioned handoffs</h3><p>
            Task and approval schemas designed for independent agent
            repositories.
          </p>
        </article>
        <article class="trust-item">
          <code>approval-policies/*</code><h3>Explicit risk</h3><p>
            Automatic, founder-approved and security-reviewed actions are
            separated.
          </p>
        </article>
        <article class="trust-item">
          <code>founders-charter/*</code><h3>Human authority</h3><p>
            Mission, operating principles, prohibited behaviour and approval
            rules.
          </p>
        </article>
      </div>
      <p style="margin-top: 30px">
        <a class="button button-secondary" href={githubUrl}
          >View source on GitHub <span aria-hidden="true">&nbsp;↗</span></a
        >
      </p>
    </div>
  </section>

  <section class="section section-dark final-cta">
    <div class="narrow">
      <p class="eyebrow">Pre-release</p>
      <h2>See what a governed AI team can do for your community.</h2>
      <p class="lead">
        Walk through the interactive narrative, then tell us where your founder
        bottleneck lives.
      </p>
      <div class="button-row">
        <a class="button" href="/demo">Watch the demo</a><a
          class="button button-secondary"
          href="/early-access">Join early access</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
