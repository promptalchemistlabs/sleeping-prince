# Kingdom-wide runtime configuration
NODE_ENV=development
LOG_LEVEL=debug
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Agent execution defaults to deterministic mock mode for local smoke tests.
ORIN_MODE=mock
SCRIBE_MODE=mock
RICK_MODE=mock
BASTION_MODE=mock

# One shared Turso database; agents use separate tables.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Telegram is Orin's public channel. Leave the token empty to use mock/API mode.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Public URLs used by Telegram and the orchestration dashboard.
KINGDOM_PUBLIC_URL=http://localhost:4000
PUBLIC_ORCHESTRATION_API_URL=http://localhost:4000
TEMBUSU_SITE_URL=http://localhost:8000

# Local service ports
KINGDOM_PORT=4000
ORIN_PORT=4101
SCRIBE_PORT=4102
RICK_PORT=4103
BASTION_PORT=4104
