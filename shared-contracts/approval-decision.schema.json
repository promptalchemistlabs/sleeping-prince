{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kingdom.pal/contracts/approval-decision/v1alpha1",
  "title": "Approval Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "approvalId", "decision", "decidedBy", "decidedAt"],
  "properties": {
    "contractVersion": { "const": "v1alpha1" },
    "approvalId": { "type": "string", "minLength": 1 },
    "decision": { "enum": ["approved", "rejected", "changes-requested"] },
    "decidedBy": { "type": "string", "minLength": 1 },
    "conditions": { "type": "array", "items": { "type": "string" } },
    "reason": { "type": ["string", "null"] },
    "decidedAt": { "type": "string", "format": "date-time" }
  }
}
