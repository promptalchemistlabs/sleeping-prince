{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kingdom.pal/contracts/agent-manifest/v1alpha1",
  "title": "Kingdom of PAL Agent Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "kingdom.pal/v1alpha1" },
    "kind": { "const": "AgentManifest" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "version", "description"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "displayName": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+$" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "tier",
        "repository",
        "capabilities",
        "contracts",
        "permissions",
        "memory",
        "boundaries",
        "approval",
        "healthcheck",
        "runtime"
      ],
      "properties": {
        "role": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "tier": { "enum": ["core", "extension"] },
        "repository": { "type": "string", "format": "uri" },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "contracts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "accepts", "returns"],
          "properties": {
            "version": { "const": "v1alpha1" },
            "accepts": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string" }
            },
            "returns": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string" }
            }
          }
        },
        "permissions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z]+:[a-z0-9-]+$" }
        },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reads", "writes"],
          "properties": {
            "reads": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string" }
            },
            "writes": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string" }
            }
          }
        },
        "boundaries": {
          "type": "object",
          "additionalProperties": false,
          "required": ["prohibited"],
          "properties": {
            "prohibited": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "approval": {
          "type": "object",
          "additionalProperties": false,
          "required": ["policy", "requiredFor"],
          "properties": {
            "policy": { "type": "string" },
            "requiredFor": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string" }
            }
          }
        },
        "healthcheck": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "path"],
          "properties": {
            "method": { "const": "GET" },
            "path": { "type": "string", "pattern": "^/" }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "enum": ["planned", "development", "ready", "deprecated"] },
            "language": { "type": "string" },
            "framework": { "type": "string" },
            "entrypoint": { "type": "string" }
          }
        }
      }
    }
  }
}
